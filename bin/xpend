#!/usr/bin/env python3
"""
xpend - View latest Grok reply
"""

import argparse
import os
import sys
from pathlib import Path

script_dir = Path(__file__).resolve().parent
lib_dir = script_dir.parent / "lib"
sys.path.insert(0, str(lib_dir))
from compat import setup_windows_encoding
setup_windows_encoding()

try:
    from cli_output import EXIT_ERROR, EXIT_NO_REPLY, EXIT_OK
    from grok_comm import GrokLogReader
    from ccb_protocol import strip_trailing_markers
    from session_utils import find_project_session_file
    from askd_client import resolve_work_dir_with_registry
    from providers import XASK_CLIENT_SPEC
except ImportError as exc:
    print(f"Import failed: {exc}")
    sys.exit(1)


def main() -> int:
    parser = argparse.ArgumentParser(description="View latest Grok reply")
    parser.add_argument("n", nargs="?", type=int, default=1, help="Number of conversations (default: 1)")
    parser.add_argument("--session-file", dest="session_file", default=None)
    args = parser.parse_args()

    work_dir, _ = resolve_work_dir_with_registry(
        XASK_CLIENT_SPEC,
        provider="grok",
        cli_session_file=args.session_file,
        env_session_file=os.environ.get("CCB_SESSION_FILE"),
    )

    session_file = find_project_session_file(work_dir, ".grok-session")
    session_id = None
    if session_file:
        try:
            import json
            data = json.loads(session_file.read_text(encoding="utf-8-sig"))
            session_id = str(data.get("grok_session_id") or "").strip() or None
        except Exception:
            pass

    reader = GrokLogReader(work_dir, session_id_filter=session_id)
    pairs = reader.latest_conversations(max(1, int(args.n)))
    if not pairs:
        print("No Grok conversations found.")
        return EXIT_NO_REPLY

    for i, (user, assistant) in enumerate(pairs, 1):
        if len(pairs) > 1:
            print(f"--- conversation {i} ---")
        print("USER:")
        print(user)
        print()
        print("GROK:")
        print(strip_trailing_markers(assistant))
        print()
    return EXIT_OK


if __name__ == "__main__":
    raise SystemExit(main())
